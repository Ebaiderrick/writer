# AI provider API key (required for AI features)
# Get a key from https://openrouter.ai or use a direct OpenAI key
OPENAI_API_KEY=your_api_key_here

# Model to use via OpenRouter (optional, defaults to openai/gpt-4o-mini)
# Examples: openai/gpt-4o, openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENAI_MODEL=openai/gpt-4o-mini

# Port the backend server listens on (optional, defaults to 3001)
PORT=3001

# AI provider base URL (optional, defaults to OpenRouter)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
