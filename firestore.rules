rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Personal projects and profile — owner only
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public user lookup by email (read: any signed-in user; write: own email only)
    match /usersByEmail/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == email;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isWorkspaceOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isWorkspaceCollaborator() {
      return isSignedIn() && request.auth.uid in resource.data.collaborators;
    }

    function collaboratorRole() {
      return isWorkspaceCollaborator() ? resource.data.collaborators[request.auth.uid].role : null;
    }

    function canEditSharedContent() {
      return isWorkspaceOwner() || (isWorkspaceCollaborator() && collaboratorRole() != 'viewer');
    }

    // Shared projects — owner or collaborators can read/write content
    match /sharedProjects/{projectId} {
      // Allow reading non-existent docs (resource==null) so the client can check
      // existence before creating; no data is exposed from a non-existent document.
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators
      );
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Owner can update anything.
        isWorkspaceOwner() ||
        // Collaborators can update content fields but NOT ownership or membership.
        (
          canEditSharedContent() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ownerId', 'ownerName', 'ownerEmail', 'collaborators'])
        ) ||
        // Admins can update collaborator membership state without touching owner fields
        // or unrelated workspace state.
        (
          isWorkspaceCollaborator() &&
          collaboratorRole() == 'admin' &&
          request.resource.data.ownerId == resource.data.ownerId &&
          request.resource.data.ownerName == resource.data.ownerName &&
          request.resource.data.ownerEmail == resource.data.ownerEmail &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['collaborators', 'updatedBy', 'lastEditorName'])
        ) ||
        // Invitee self-add: only allowed change is adding own uid to collaborators + updatedBy.
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['collaborators', 'updatedBy']) &&
          request.auth.uid in request.resource.data.collaborators &&
          !(request.auth.uid in resource.data.collaborators)
        )
      );
      allow delete: if isSignedIn() &&
        resource.data.ownerId == request.auth.uid;
    }

    match /sharedProjects/{projectId}/presence/{userId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators
      );
      allow create, update: if isSignedIn() && request.auth.uid == userId && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    match /sharedProjects/{projectId}/versions/{versionId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators
      );
      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators[request.auth.uid].role != 'viewer'
        )
      );
      allow update, delete: if isSignedIn() &&
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // Comments — readable/writable by project members
    match /sharedProjects/{projectId}/comments/{commentId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators
      );
      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators &&
          (
            get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators[request.auth.uid].role != 'viewer' ||
            get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.workspace.commentingEnabled == true
          )
        )
      );
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators[request.auth.uid].role != 'viewer'
        )
      );
    }

    match /workspace_members/{memberId} {
      allow read: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspace_id)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspace_id)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspace_id)).data.collaborators[request.auth.uid].role == 'admin'
        )
      );
      allow create, update: if request.auth != null && (
        get(/databases/$(database)/documents/sharedProjects/$(request.resource.data.workspace_id)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(request.resource.data.workspace_id)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(request.resource.data.workspace_id)).data.collaborators[request.auth.uid].role == 'admin'
        ) ||
        request.resource.data.user_id == request.auth.uid
      );
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspace_id)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspace_id)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspace_id)).data.collaborators[request.auth.uid].role == 'admin'
        ) ||
        resource.data.user_id == request.auth.uid
      );
    }

    // Invitations — sender can create/delete; recipient can read and update status
    match /invitations/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email ||
        (
          resource.data.workspaceId != null &&
          (
            get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspaceId)).data.ownerId == request.auth.uid ||
            (
              request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspaceId)).data.collaborators &&
              get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspaceId)).data.collaborators[request.auth.uid].role == 'admin'
            )
          )
        )
      );
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null &&
        (
          resource.data.toEmail == request.auth.token.email ||
          resource.data.fromUid == request.auth.uid
        );
      allow delete: if request.auth != null &&
        (
          resource.data.fromUid == request.auth.uid ||
          (
            resource.data.workspaceId != null &&
            (
              get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspaceId)).data.ownerId == request.auth.uid ||
              (
                request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspaceId)).data.collaborators &&
                get(/databases/$(database)/documents/sharedProjects/$(resource.data.workspaceId)).data.collaborators[request.auth.uid].role == 'admin'
              )
            )
          )
        );
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
