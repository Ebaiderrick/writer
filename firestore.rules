rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper — true when the caller has a record in the admins collection
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Personal projects and profile — owner or admin
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Billing and AI usage — owner only, no client write except via server-side admin SDK
    match /users/{userId}/billing/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    match /users/{userId}/aiUsage/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    // Quota — owner can read and update count/resetAt; plan is server-managed only
    match /users/{userId}/quota/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['plan']);
    }

    // Public user lookup by email (read: any signed-in user; write: own record only)
    match /usersByEmail/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == email
        && request.resource.data.uid == request.auth.uid;
    }

    // ── Shared project helpers ──────────────────────────────────────────────
    function sharedProject(projectId) {
      return get(/databases/$(database)/documents/sharedProjects/$(projectId)).data;
    }
    function isSharedProjectOwner(projectId) {
      return sharedProject(projectId).ownerId == request.auth.uid;
    }
    function isSharedProjectMember(projectId) {
      let p = sharedProject(projectId);
      return p.ownerId == request.auth.uid || request.auth.uid in p.collaborators;
    }
    function isSharedProjectEditor(projectId) {
      let p = sharedProject(projectId);
      return p.ownerId == request.auth.uid || (
        request.auth.uid in p.collaborators &&
        p.collaborators[request.auth.uid].role != 'viewer'
      );
    }

    // Shared projects — owner or collaborators can read/write content
    match /sharedProjects/{projectId} {
      // Allow reading non-existent docs (resource==null) so the client can check
      // existence before creating; no data is exposed from a non-existent document.
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators
      );
      // Only the owner-to-be can create; they must stamp their own uid.
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.collaborators is map;
      // Update paths — three distinct cases:
      allow update: if request.auth != null && (
        // 1. Owner can update anything EXCEPT ownership fields (transfer must go server-side).
        (
          resource.data.ownerId == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'ownerEmail'])
        ) ||
        // 2. Non-viewer collaborators can update content fields only.
        //    Ownership fields (including ownerPhotoURL) and membership are locked.
        (
          request.auth.uid in resource.data.collaborators &&
          resource.data.collaborators[request.auth.uid].role != 'viewer' &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ownerId', 'ownerName', 'ownerEmail', 'ownerPhotoURL', 'collaborators'])
        ) ||
        // 3. Invitee self-add: caller may ONLY add themselves to collaborators (+ updatedBy).
        //    Role must be a valid value; existing collaborators map entries are preserved.
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['collaborators', 'updatedBy']) &&
          request.resource.data.updatedBy == request.auth.uid &&
          request.auth.uid in request.resource.data.collaborators &&
          !(request.auth.uid in resource.data.collaborators) &&
          request.resource.data.collaborators[request.auth.uid].role in ['editor', 'viewer']
        )
      );
      // Owner or admin can delete.
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
    }

    // Presence — members write their own heartbeat; any member can read
    match /sharedProjects/{projectId}/presence/{uid} {
      allow read: if request.auth != null && isSharedProjectMember(projectId);
      allow write: if request.auth != null && request.auth.uid == uid && isSharedProjectMember(projectId);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Comments — readable/writable/deletable by project members
    match /sharedProjects/{projectId}/comments/{commentId} {
      allow read: if request.auth != null && isSharedProjectMember(projectId);
      // Non-viewer members can create comments stamped with their own uid.
      allow create: if request.auth != null &&
        isSharedProjectEditor(projectId) &&
        request.resource.data.uid == request.auth.uid;
      // Comment author or non-viewer member can update (resolve/unresolve).
      allow update: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        isSharedProjectEditor(projectId)
      );
      // Comment author, project owner, or admin can delete.
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        isSharedProjectOwner(projectId) ||
        isAdmin()
      );
    }

    // Invitations — sender can create/delete; recipient can read and update status
    match /invitations/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      // Sender can only create an invite stamped with their own uid and a valid role
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.role in ['editor', 'viewer'] &&
        request.resource.data.status == 'pending';
      // Recipient can only update status field (accept/decline their own invite)
      allow update: if request.auth != null &&
        resource.data.toEmail == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['accepted', 'declined'];
      allow delete: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        isAdmin()
      );
    }

    // Waitlist — anyone can submit; only admins can read/manage
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admin identity — admins read their own record; no client write ever
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Feature flags — any signed-in user can read; only admins can write
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Incidents — public read (including signed-out); only admins can write
    match /incidents/{incidentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin aggregate data (flat top-level collections)
    // signupRecords: owner creates their own record on signup; admins can manage
    match /adminSignups/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read, update, delete: if isAdmin();
    }
    // feedback: any auth'd user can submit, stamped with their uid; admins can manage
    match /adminFeedback/{feedbackId} {
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
    // activeUsers: owner or admin can read/write
    match /adminActiveUsers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, update, delete: if isAdmin();
    }

    // Webhook event idempotency store — admin SDK writes only; no client access
    match /webhookEvents/{eventId} {
      allow read, write: if false;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
