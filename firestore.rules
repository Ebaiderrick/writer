rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper — true when the caller has a record in the admins collection
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Personal projects and profile — owner or admin
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Billing and AI usage — owner only, no client write except via server-side admin SDK
    match /users/{userId}/billing/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    match /users/{userId}/aiUsage/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    // Quota — owner read/write (client-tracked for free users)
    match /users/{userId}/quota/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public user lookup by email (read: any signed-in user; write: own record only)
    match /usersByEmail/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == email
        && request.resource.data.uid == request.auth.uid;
    }

    // Shared projects — owner or collaborators can read/write content
    match /sharedProjects/{projectId} {
      // Allow reading non-existent docs (resource==null) so the client can check
      // existence before creating; no data is exposed from a non-existent document.
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        // Owner can update anything.
        resource.data.ownerId == request.auth.uid ||
        // Collaborators can update content fields but NOT ownership or membership.
        (
          request.auth.uid in resource.data.collaborators &&
          resource.data.collaborators[request.auth.uid].role != 'viewer' &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ownerId', 'ownerName', 'ownerEmail', 'collaborators'])
        ) ||
        // Invitee self-add: only allowed change is adding own uid to collaborators + updatedBy.
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['collaborators', 'updatedBy']) &&
          request.auth.uid in request.resource.data.collaborators &&
          !(request.auth.uid in resource.data.collaborators)
        )
      );
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // Comments — readable/writable by project members
    match /sharedProjects/{projectId}/comments/{commentId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators
      );
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators[request.auth.uid].role != 'viewer'
        )
      );
      allow update: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.ownerId == request.auth.uid ||
        (
          request.auth.uid in get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators &&
          get(/databases/$(database)/documents/sharedProjects/$(projectId)).data.collaborators[request.auth.uid].role != 'viewer'
        )
      );
    }

    // Invitations — sender can create/delete; recipient can read and update status
    match /invitations/{inviteId} {
      allow read: if request.auth != null && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.toEmail == request.auth.token.email;
      allow delete: if request.auth != null &&
        resource.data.fromUid == request.auth.uid;
    }

    // Waitlist — anyone can submit; only admins can read/manage
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admin identity — admins read their own record; no client write ever
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Feature flags — any signed-in user can read; only admins can write
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Incidents — public read (including signed-out); only admins can write
    match /incidents/{incidentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin aggregate data (flat top-level collections)
    // signupRecords: owner creates their own record on signup; admins can manage
    match /adminSignups/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read, update, delete: if isAdmin();
    }
    // feedback: any auth'd user can submit, stamped with their uid; admins can manage
    match /adminFeedback/{feedbackId} {
      allow create: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
    // activeUsers: owner or admin can read/write
    match /adminActiveUsers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, update, delete: if isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
